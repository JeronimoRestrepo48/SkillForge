# =============================================================================
# SkillForge - Variables de entorno
# =============================================================================
# Copiar a .env en la raíz del proyecto (desarrollo/.env) y ajustar valores.
# En producción NUNCA uses las claves por defecto ni subas .env al repositorio.
# =============================================================================

# -----------------------------------------------------------------------------
# Seguridad
# -----------------------------------------------------------------------------
# Clave secreta de Django (sesiones, CSRF, firmas, etc.).
# Generar una nueva: python -c "import secrets; print(secrets.token_hex(50))"
SECRET_KEY=your-secret-key-here-change-in-production

# -----------------------------------------------------------------------------
# Entorno
# -----------------------------------------------------------------------------
# True = modo desarrollo (páginas de error detalladas, static/media servidos por Django).
# False = obligatorio en producción.
DEBUG=True

# Hosts permitidos, separados por coma (sin espacios). En producción añadir dominio real.
# Ejemplo producción: ALLOWED_HOSTS=skillforge.example.com,www.skillforge.example.com
ALLOWED_HOSTS=localhost,127.0.0.1

# -----------------------------------------------------------------------------
# Base de datos
# -----------------------------------------------------------------------------
# Por defecto SQLite (desarrollo). Para PostgreSQL:
# DATABASE_URL=postgres://usuario:contraseña@localhost:5432/nombre_bd
# Para MySQL: mysql://usuario:contraseña@localhost:3306/nombre_bd
DATABASE_URL=sqlite:///db.sqlite3

# -----------------------------------------------------------------------------
# Email
# -----------------------------------------------------------------------------
# Remitente por defecto de los correos enviados por la aplicación.
# En desarrollo el backend suele ser 'console' (ver config/settings/development.py).
DEFAULT_FROM_EMAIL=noreply@skillforge.local

# -----------------------------------------------------------------------------
# Microservicios (JWT Secret)
# -----------------------------------------------------------------------------
JWT_SECRET=your-jwt-secret-here

# -----------------------------------------------------------------------------
# AWS S3 (Fase 2 — almacenamiento de media en producción)
# -----------------------------------------------------------------------------
# Sin estas variables Django usa el filesystem local (desarrollo).
# En producción, crear un bucket S3 privado y una distribución CloudFront opcional.
#
# AWS_STORAGE_BUCKET_NAME=skillforge-media-prod
# AWS_S3_REGION_NAME=us-east-1
#
# Credenciales IAM (usa un usuario con permisos s3:PutObject / s3:GetObject sobre el bucket).
# boto3 también las lee de ~/.aws/credentials o de rol IAM en EC2/ECS automáticamente.
# AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
# AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY
#
# (Opcional) Si tienes una distribución CloudFront delante del bucket:
# AWS_CLOUDFRONT_DOMAIN=d1234abcdef8.cloudfront.net

# ---------------------------------------------------------------------------
# Backups automáticos nocturnos (scripts/backup_databases.py via Celery Beat)
# ---------------------------------------------------------------------------
# Bucket S3 EXCLUSIVO para backups de BD. Separado del bucket de media.
# Si no se define, los backups se guardan localmente en /tmp/skillforge_backups/.
#
# AWS_BACKUP_BUCKET=skillforge-backups-prod
#
# Directorio local de backups (cuando S3 no está configurado):
# BACKUP_DIR=/var/backups/skillforge
#
# Credenciales de las BDs de microservicios (usadas solo por el script de backup).
# En Docker, los defaults del script (auth-db, catalog-db, transactions-db) son correctos.
# Solo necesitas cambiarlos si apuntan a hosts externos en producción.
# AUTH_DB_HOST=auth-db
# AUTH_DB_USER=auth
# AUTH_DB_PASSWORD=auth
# AUTH_DB_NAME=authdb
# CATALOG_DB_HOST=catalog-db
# CATALOG_DB_USER=catalog
# CATALOG_DB_PASSWORD=catalog
# CATALOG_DB_NAME=catalogdb
# TRANSACTIONS_DB_HOST=transactions-db
# TRANSACTIONS_DB_USER=transactions
# TRANSACTIONS_DB_PASSWORD=transactions
# TRANSACTIONS_DB_NAME=transactionsdb

