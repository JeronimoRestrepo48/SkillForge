# =============================================================================
# SkillForge - Variables de entorno
# =============================================================================
# Copiar a .env en la raíz del proyecto (desarrollo/.env) y ajustar valores.
# En producción NUNCA uses las claves por defecto ni subas .env al repositorio.
# =============================================================================

# -----------------------------------------------------------------------------
# Seguridad
# -----------------------------------------------------------------------------
# Clave secreta de Django (sesiones, CSRF, firmas, etc.).
# Generar una nueva: python -c "import secrets; print(secrets.token_hex(50))"
SECRET_KEY=your-secret-key-here-change-in-production

# -----------------------------------------------------------------------------
# Entorno
# -----------------------------------------------------------------------------
# True = modo desarrollo (páginas de error detalladas, static/media servidos por Django).
# False = obligatorio en producción.
DEBUG=True

# Hosts permitidos, separados por coma (sin espacios). En producción añadir dominio real.
# Ejemplo producción: ALLOWED_HOSTS=skillforge.example.com,www.skillforge.example.com
ALLOWED_HOSTS=localhost,127.0.0.1

# -----------------------------------------------------------------------------
# Base de datos
# -----------------------------------------------------------------------------
# Por defecto SQLite (desarrollo). Para PostgreSQL:
# DATABASE_URL=postgres://usuario:contraseña@localhost:5432/nombre_bd
# Para MySQL: mysql://usuario:contraseña@localhost:3306/nombre_bd
DATABASE_URL=sqlite:///db.sqlite3

# -----------------------------------------------------------------------------
# Email
# -----------------------------------------------------------------------------
# Remitente por defecto de los correos enviados por la aplicación.
# En desarrollo el backend suele ser 'console' (ver config/settings/development.py).
DEFAULT_FROM_EMAIL=noreply@skillforge.local

# -----------------------------------------------------------------------------
# Opcional (producción)
# -----------------------------------------------------------------------------
# Si en el futuro se usa un módulo settings de producción:
# DJANGO_SETTINGS_MODULE=config.settings.production
#
# Para SMTP en producción, típicamente se usan variables como:
# EMAIL_HOST=smtp.example.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=...
# EMAIL_HOST_PASSWORD=...
# (Su uso depende de que esté implementado en config/settings/production.py)

# -----------------------------------------------------------------------------
# Redis / Celery (Entregable 2 — Docker Compose y AWS)
# -----------------------------------------------------------------------------
# REDIS_URL=redis://redis:6379/0
# CELERY_BROKER_URL=redis://redis:6379/0
# CELERY_RESULT_BACKEND=redis://redis:6379/0
# CELERY_TASK_ALWAYS_EAGER=False

# -----------------------------------------------------------------------------
# Integración entre equipos (Entregable 2)
# -----------------------------------------------------------------------------
# URL base del equipo aliado (Elastic IP EC2, sin barra final)
# ALLY_SERVICE_URL=http://3.85.xxx.xxx
# ALLY_SERVICE_PUBLIC_PATH=api/integration/skillforge/public/
# ALLY_SERVICE_TIMEOUT=8

# -----------------------------------------------------------------------------
# API de terceros (Adapter — tipo de cambio)
# -----------------------------------------------------------------------------
# FRANKFURTER_API_URL=https://api.frankfurter.app
